# Copy to .env.local for local `npm run dev`, and set the same values as
# Environment Variables in the Vercel project dashboard for the deployed app.

# Supabase project -> Project Settings -> API
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Same OpenRouter key used by the local Python pipeline
OPENROUTER_API_KEY=sk-or-v1-...

# Public — reach the browser bundle, used only to PUT an uploaded video straight to
# Supabase Storage via a signed URL. Safe to expose: the publishable key has zero
# table/bucket grants of its own (see migration.sql); the signed URL's token is the
# actual authorization. Same values as SUPABASE_URL / the publishable ("anon"-equivalent) key.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
