# Copy to .env.local for local `npm run dev`, and set the same values as
# Environment Variables in the Vercel project dashboard for the deployed app.

# Supabase project -> Project Settings -> API
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Same OpenRouter key used by the local Python pipeline
OPENROUTER_API_KEY=sk-or-v1-...

# Pick your own values — this gates the whole app behind a single shared password.
APP_PASSWORD=choose-a-password
SESSION_SECRET=choose-a-long-random-string
