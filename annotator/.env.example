# Documentation only — this project reads these from real environment variables
# (PowerShell: setx VAR "value"), it does not load a .env file.

OPENROUTER_API_KEY=sk-or-v1-...

# Only needed for `python -m annotator push` / `watch` (hosted review on Vercel).
# Supabase project -> Project Settings -> API. Use the service_role key, not anon.
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
